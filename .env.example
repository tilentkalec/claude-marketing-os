# claude-marketing-os — credentials
#
# Copy this file to `.env` and fill in only the keys for the channels you actually run.
# Convention: <CHANNEL>_<KEY_TYPE>_<MARKET_CODE>
# Market codes match the Markets table in `client-config.md` (e.g., US, UK, DE, SI).

# ─── Klaviyo (one API key per market) ──────────────────────────────────────────
# KLAVIYO_API_KEY_US=pk_...
# KLAVIYO_API_KEY_UK=pk_...

# ─── Google Ads (one account ID per market + shared developer token / refresh) ─
# GOOGLE_ADS_ACCOUNT_ID_US=...
# GOOGLE_ADS_ACCOUNT_ID_UK=...
# GOOGLE_ADS_DEVELOPER_TOKEN=...
# GOOGLE_ADS_CLIENT_ID=...
# GOOGLE_ADS_CLIENT_SECRET=...
# GOOGLE_ADS_REFRESH_TOKEN=...

# ─── Meta Ads (one account ID + pixel per market + shared access token) ────────
# META_ACCOUNT_ID_US=act_...
# META_ACCOUNT_ID_UK=act_...
# META_PIXEL_ID_US=...
# META_PIXEL_ID_UK=...
# META_ACCESS_TOKEN=...

# ─── GA4 (one property ID per market + shared service account) ─────────────────
# GA4_PROPERTY_ID_US=...
# GA4_PROPERTY_ID_UK=...
# GA4_SERVICE_ACCOUNT_PATH=./service-account.json

# ─── Commerce / revenue source ─────────────────────────────────────────────────
# Pick whichever you use:
# STRIPE_API_KEY=sk_...
# SHOPIFY_ADMIN_TOKEN=shpat_...
# WP_BASIC_AUTH_USER_US=...
# WP_BASIC_AUTH_PASS_US=...

# ─── WordPress (per market, if running content via WP) ─────────────────────────
# WP_SITE_URL_US=https://example.com
# WP_USERNAME_US=...
# WP_APP_PASSWORD_US=...

# ─── Optional: AI / utility services ───────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
